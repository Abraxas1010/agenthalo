{
  "schema": "nucleusdb/attestation-evidence-retention-policy/v1",
  "root_dir": "artifacts/ops/attestation_promotion_required",
  "run_dir_glob": "run_*",
  "keep_last": 20,
  "max_age_days": 30,
  "trash_subdir": ".trash",
  "require_signed_bundle": true,
  "required_bundle_files": [
    "evidence_bundle/manifest.sha512",
    "evidence_bundle/manifest.sig",
    "evidence_bundle/manifest_pub.pem",
    "evidence_bundle/bundle_metadata.json"
  ]
}
