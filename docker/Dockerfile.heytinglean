FROM rust:1.88-bookworm AS cache-builder

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git xz-utils zstd \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://raw.githubusercontent.com/leanprover/elan/master/elan-init.sh \
    | sh -s -- -y --default-toolchain stable

ENV PATH=/root/.elan/bin:${PATH}

WORKDIR /build
COPY docker/.heytinglean-build/ /build/heyting/
COPY docker/.heytinglean-build/packages/ /build/heyting/.lake/packages/

WORKDIR /build/heyting
RUN lake build \
    HeytingLean.NucleusDB \
    HeytingLean.Bridge.Sharma \
    HeytingLean.EpistemicCalculus.EpistemicCalculus \
    HeytingLean.Crypto.Commit \
    HeytingLean.CLI.LambdaKernelExportMain \
    HeytingLean.CLI.LensExportMain \
    HeytingLean.CLI.CABVerifyExportMain

RUN mkdir -p /opt/heytinglean-cache \
    && cp -R .lake /opt/heytinglean-cache/.lake \
    && cp lakefile.lean /opt/heytinglean-cache/lakefile.lean \
    && cp lean-toolchain /opt/heytinglean-cache/lean-toolchain \
    && if [ -f lake-manifest.json ]; then cp lake-manifest.json /opt/heytinglean-cache/lake-manifest.json; fi

# Runtime intentionally keeps the Rust/Lean toolchain because the local
# compile-fallback path runs lake/cargo inside the container when no worker
# claims a task.
FROM rust:1.88-bookworm AS runtime

ENV AGENTHALO_HEYTINGLEAN_CACHE_DIR=/opt/heytinglean-cache
ENV PATH=/root/.elan/bin:${PATH}

WORKDIR /app

COPY --from=cache-builder /root/.elan /root/.elan
COPY --from=cache-builder /opt/heytinglean-cache /opt/heytinglean-cache
COPY . /app

RUN cargo build --release --bin agenthalo --bin agenthalo-mcp-server

CMD ["/app/target/release/agenthalo", "serve"]
