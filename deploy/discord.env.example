NUCLEUSDB_DISCORD_TOKEN=
NUCLEUSDB_DISCORD_DB_PATH=/var/lib/agenthalo/discord_records.ndb
NUCLEUSDB_DISCORD_CHANNELS=all
NUCLEUSDB_DISCORD_BATCH_SIZE=10
NUCLEUSDB_DISCORD_BATCH_TIMEOUT_SECS=5
NUCLEUSDB_DISCORD_RECORD_BOTS=false
NUCLEUSDB_DISCORD_RECORD_EDITS=true
NUCLEUSDB_DISCORD_RECORD_DELETES=true
# Optional for the HTTP AgentHALO MCP service:
# AGENTHALO_MCP_HOST=127.0.0.1
# AGENTHALO_MCP_PORT=3000
# AGENTHALO_MCP_SECRET=replace-with-random-bearer-secret
RUST_LOG=nucleusdb=info
